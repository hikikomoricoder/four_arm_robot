<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">
    <xacro:macro name="veer_link" params="prefix">
        <link name="veer_link_${prefix}" >
            <visual>
                <geometry>
                    <box size="${veer_length} ${veer_width} ${veer_height}" />
                </geometry>
                <origin xyz="0 0 -${veer_height/2}" rpy="0 0 0" />
                <material name="wheel_joint_color" />
            </visual>
            <collision>
                <geometry>
                    <box size="${veer_length} ${veer_width} ${veer_height}" />
                </geometry>
                <origin xyz="0 0 -${veer_height/2}" rpy="0 0 0" />
            </collision>
            <xacro:box_inertia m="2.0" x="${veer_length}" y="${veer_width}" z="${veer_height}"
                            o_xyz="0 0 0" o_rpy="0 0 0" />
        </link>
    </xacro:macro>

    <xacro:macro name="wheel_link" params="prefix">
        <link name="wheel_link_${prefix}">
            <visual>
                <geometry>
                    <cylinder radius="${wheel_radius}" length="${wheel_length}" />
                </geometry>
                <origin xyz="0 0 0" rpy="${pi / 2.0} 0 0" />
                <material name="wheel_color" />
            </visual>
            <collision>
                <geometry>
                    <sphere radius="0.1" />
                </geometry>
                <origin xyz="0 0 0" rpy="0 0 0" />
            </collision>
            <xacro:cylinder_inertia m="1.0" r="${wheel_radius}" l="${wheel_length}"
                    o_xyz="0 0 0" o_rpy="${pi / 2.0} 0 0"/>
        </link>
    </xacro:macro>

    <xacro:veer_link prefix="1" />
    <xacro:wheel_link prefix="1" />

    <xacro:veer_link prefix="2" />
    <xacro:wheel_link prefix="2" />

    <xacro:veer_link prefix="3" />
    <xacro:wheel_link prefix="3" />

    <xacro:veer_link prefix="4" />
    <xacro:wheel_link prefix="4" />

    <xacro:macro name="wheel_joint" params="prefix">
        <joint name="wheel_joint_${prefix}" type="continuous">
            <parent link="veer_link_${prefix}" />
            <child link="wheel_link_${prefix}" />
            <origin xyz="0 0 -${wheel_radius+veer_height}" rpy="0 0 0" />
            <axis xyz="0 1 0" />
        </joint>
    </xacro:macro>

    <xacro:wheel_joint prefix="1" />
    <xacro:wheel_joint prefix="2" />
    <xacro:wheel_joint prefix="3" />
    <xacro:wheel_joint prefix="4" />
</robot>